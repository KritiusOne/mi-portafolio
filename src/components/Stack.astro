---
import { techStack } from "@/utils/techStack";
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-2 place-content-center">
  <div
    class="flex flex-col gap-3 justify-center items-center bg-slate-400 dark:bg-slate-900 py-2 rounded"
  >
    <h3 class="text-2xl font-bold text-gray-800 dark:text-gray-100">
      Front-end
    </h3>
    <div class="flex flex-row flex-wrap justify-center items-center gap-2">
      {
        techStack.front.map((item) => (
          <article class="w-fit flex flex-col justify-center items-center gap-1">
            <item.icon class="size-16" />
            <span class="text-slate-950 dark:text-slate-100">{item.name} </span>
          </article>
        ))
      }
    </div>
  </div>

  <div
    class="flex flex-col gap-3 justify-center items-center bg-slate-400 dark:bg-slate-900 px-4 py-2 rounded"
  >
    <h3 class="text-2xl font-bold text-gray-800 dark:text-gray-100">
      Back-end
    </h3>
    <div class="flex flex-row flex-wrap justify-center items-center gap-2">
      {
        techStack.back.map((item) => (
          <article class="w-fit flex flex-col justify-center items-center gap-1">
            <item.icon class="size-16" />
            <span class="text-slate-950 dark:text-slate-100">{item.name} </span>
          </article>
        ))
      }
    </div>
  </div>

  <div
    class="flex flex-col gap-3 justify-center items-center bg-slate-400 dark:bg-slate-900 px-4 py-2 rounded"
  >
    <h3 class="text-2xl font-bold text-gray-800 dark:text-gray-100">
      Bases de datos
    </h3>
    <div class="flex flex-row flex-wrap justify-center items-center gap-2">
      {
        techStack.bbdd.map((item) => (
          <article class="w-fit flex flex-col justify-center items-center gap-1">
            <item.icon class="size-16" />
            <span class="text-slate-950 dark:text-slate-100">{item.name} </span>
          </article>
        ))
      }
    </div>
  </div>

  <div
    class="flex flex-col gap-3 justify-center items-center bg-slate-400 dark:bg-slate-900 px-4 py-2 rounded"
  >
    <h3 class="text-2xl font-bold text-gray-800 dark:text-gray-100">Tools</h3>
    <div class="flex flex-row flex-wrap justify-center items-center gap-2">
      {
        techStack.tools.map((item) => (
          <article class="w-fit flex flex-col justify-center items-center gap-1">
            <item.icon class="size-16" />
            <span class="text-slate-950 dark:text-slate-100">{item.name}</span>
          </article>
        ))
      }
    </div>
  </div>
</div>

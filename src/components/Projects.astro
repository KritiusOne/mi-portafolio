---
import GitHub from "./icons/GitHub.astro";
import React from "./icons/React.astro";
import Tailwind from "./icons/Tailwind.astro";
import Link from "./icons/Link.astro";
import LinkButton from "./LinkButton.astro";
import Javascript from "./icons/Javascript.astro";
import CssIcon from "./icons/Css.astro";
import HTMLIcon from "./icons/HTML.astro";
import Typescript from "./icons/Typescript.astro";
import AstroIcon from "./icons/AstroIcon.astro";
import CSharpIcon from "./icons/Csharp.astro";
import DotnetIcon from "./icons/DotnetIcon.astro";
import SQLServerIcon from "./icons/SQLServerIcon.astro";
import { getLangFromUrl } from "@/i18n/utils";
import ExpressIcon from "./icons/Express.astro";
import NodeIcon from "./icons/Nodejs.astro";
import MongoIcon from "./icons/MongoDBIcon.astro";
interface Project {
  title: string;
  description: string;
  image: string;
  link?: string;
  github?: string;
  tags: {
    name: string;
    class: string;
    icon: any;
  }[];
}
interface projByLangs {
  es: {
    codeLabel: string;
    previewLabel: string;
    imageAlt: string;
    items: Project[];
  };
  en: {
    codeLabel: string;
    previewLabel: string;
    imageAlt: string;
    items: Project[];
  };
}
const lang = getLangFromUrl(Astro.url);

const TAGS = {
  HTML: {
    name: "HTML5",
    class: "bg-orange-300 text-black",
    icon: HTMLIcon,
  },
  CSS: {
    name: "CSS",
    class: "bg-[#003159] text-white",
    icon: CssIcon,
  },
  TAILWIND: {
    name: "Tailwind CSS",
    class: "bg-[#003159] text-white",
    icon: Tailwind,
  },
  JS: {
    name: "Javascript",
    class: "bg-slate-900 text-white",
    icon: Javascript,
  },
  React: {
    name: "React.js",
    class: "bg-black text-white",
    icon: React,
  },
  Typescript: {
    name: "Typescript",
    class: "bg-blue-300 text-black",
    icon: Typescript,
  },
  Astro: {
    name: "Astro",
    class: "bg-orange-400 text-black",
    icon: AstroIcon,
  },
  CSharp: {
    name: "C#",
    class: "bg-green-400 text-black",
    icon: CSharpIcon,
  },
  Dotnet: {
    name: ".NET",
    class: "bg-white text-black",
    icon: DotnetIcon,
  },
  SQLServer: {
    name: "SQL Server",
    class: "bg-red-400 text-white",
    icon: SQLServerIcon,
  },
  Express: {
    name: "Express.js",
    class: "bg-gray-800 text-white",
    icon: ExpressIcon,
  },
  Nodejs: {
    name: "Node.js",
    class: "bg-green-600 text-white",
    icon: NodeIcon,
  },
  MongoDB: {
    name: "MongoDB",
    class: "bg-white text-black",
    icon: MongoIcon,
  }
};
const projectsByLang: projByLangs = {
  es: {
    codeLabel: "Codigo",
    previewLabel: "Vista previa",
    imageAlt: "Imagen del proyecto",
    items: [
      {
        title: "Smaller",
        description: "Aplicación Full stack para recortar links, construida con Next.js, Tailwind CSS, TypeScript, Node.js, Express.js y MongoDB, y desplegada en Vercel y Railway. Permite a los usuarios generar URLs cortas personalizadas, gestionar sus enlaces y acceder a estadísticas detalladassobre el rendimiento de cada enlace.",
        link: "https://smaller-frontend.vercel.app/",
        github: "https://github.com/KritiusOne/smaller-frontend",
        image: "/projects/smaller-home.webp",
        tags: [TAGS.Typescript, TAGS.TAILWIND, TAGS.React, TAGS.Nodejs, TAGS.Express, TAGS.MongoDB]
      },
      {
        title: "Fake Rubik Store",
        description:
          "Plataforma de e-commerce unica, dedicada a los amantes de los cubos de Rubik. Desarrollada con tecnologias como React, CSS, Tailwind, TypeScript y Vercel. Ofrece una amplia variedad de productos y una experiencia de compra personalizada a traves de la implementacion de una API RESTful altamente eficiente.",
        link: "https://fake-rubik-store-front-end.vercel.app/",
        github: "https://github.com/KritiusOne/FakeRubikStore-Front-end",
        image: "/projects/fake-rubik-store-home-2.webp",
        tags: [TAGS.Typescript, TAGS.CSS, TAGS.React, TAGS.TAILWIND]
      },
      {
        title: "Fake Rubik Store RESTful API",
        description:
          "API RESTful robusta y escalable para aplicaciones de comercio electronico. Construida con C#, .NET, Entity Framework y SQL Server, y desplegada en Azure, ofrece un rendimiento optimo y una integracion sencilla con otras herramientas. Incluye autenticacion JWT, gestion de inventario, busqueda avanzada y mucho mas.",
        link: "https://fake-rubik-store-docs.vercel.app/",
        github: "https://github.com/KritiusOne/FakeRubikStoreAPI",
        image: "/projects/API-docs-2.webp",
        tags: [TAGS.CSharp, TAGS.Dotnet, TAGS.SQLServer]
      },
      {
        title: "Climatacion",
        description:
          "Aplicacion front-end que implementa la API de OpenWeatherMap para reportar el estado del clima. Construida con HTML, CSS y JavaScript, y desplegada en GitHub Pages, permite consultar el clima de cualquier ciudad soportada por la API.",
        link: "https://kritiusone.github.io/Climataci-n/",
        github: "https://github.com/KritiusOne/climataci-n",
        image: "/projects/Climataci-n2.webp",
        tags: [TAGS.HTML, TAGS.CSS, TAGS.JS]
      }
    ]
  },
  en: {
    codeLabel: "Code",
    previewLabel: "Preview",
    imageAlt: "Project image",
    items: [
      {
        title: "Smaller",
        description: "Full stack application to cut links, built with Next.js, Tailwind CSS, TypeScript, Node.js, Express.js and MongoDB, and deployed on Vercel and Railway. Allows users to generate custom short URLs, manage their links and access detailed statistics about each link's performance.",
        link: "https://smaller-frontend.vercel.app/",
        github: "https://github.com/KritiusOne/smaller-frontend",
        image: "/projects/smaller-home.webp",
        tags: [TAGS.Typescript, TAGS.TAILWIND, TAGS.React, TAGS.Nodejs, TAGS.Express, TAGS.MongoDB]
      },
      {
        title: "Fake Rubik Store",
        description:
          "A unique e-commerce platform for Rubik's cube enthusiasts. Built with technologies such as React, CSS, Tailwind, TypeScript and Vercel. It offers a wide product catalog and a personalized shopping experience powered by a highly efficient RESTful API.",
        link: "https://fake-rubik-store-front-end.vercel.app/",
        github: "https://github.com/KritiusOne/FakeRubikStore-Front-end",
        image: "/projects/fake-rubik-store-home-2.webp",
        tags: [TAGS.Typescript, TAGS.CSS, TAGS.React, TAGS.TAILWIND]
      },
      {
        title: "Fake Rubik Store RESTful API",
        description:
          "A robust and scalable RESTful API for e-commerce applications. Built with C#, .NET, Entity Framework and SQL Server, and deployed on Azure, it delivers strong performance and easy integration with other tools. It includes JWT authentication, inventory management, advanced search and more.",
        link: "https://fake-rubik-store-docs.vercel.app/",
        github: "https://github.com/KritiusOne/FakeRubikStoreAPI",
        image: "/projects/API-docs-2.webp",
        tags: [TAGS.CSharp, TAGS.Dotnet, TAGS.SQLServer]
      },
      {
        title: "Weather App",
        description:
          "Front-end application that uses the OpenWeatherMap API to report weather conditions. Built with HTML, CSS and JavaScript, and deployed on GitHub Pages, it allows users to check the weather for any city supported by the API.",
        link: "https://kritiusone.github.io/Climataci-n/",
        github: "https://github.com/KritiusOne/climataci-n",
        image: "/projects/Climataci-n2.webp",
        tags: [TAGS.HTML, TAGS.CSS, TAGS.JS]
      }
    ]
  }
} as const;

const projectsContent = projectsByLang[lang] ?? projectsByLang.es;
---

<div class="flex flex-col gap-y-16">
  {
    projectsContent.items.map(({ image, title, description, tags, link, github }) => (
      <article class="flex flex-col space-x-0 space-y-8 group md:flex-row md:space-x-8 md:space-y-0">
        <div class="w-full md:w-1/2">
          <div class="relative flex flex-col items-center col-span-6 row-span-5 gap-8 transition duration-500 ease-in-out transform shadow-xl overflow-clip rounded-xl sm:rounded-xl md:group-hover:-translate-y-1 md:group-hover:shadow-2xl lg:border lg:border-gray-800 lg:hover:border-gray-700 lg:hover:bg-gray-800/50">
            <img
              alt={projectsContent.imageAlt}
              class="object-cover object-top w-full h-56 transition duration-500 sm:h-full md:scale-110 md:group-hover:scale-105"
              loading="lazy"
              src={image}
            />
          </div>
        </div>

        <div class="w-full md:w-1/2 md:max-w-lg">
          <h3 class="text-2xl font-bold text-gray-800 dark:text-gray-100">
            {title}
          </h3>
          <div class="flex flex-wrap mt-2">
            <ul class="flex flex-wrap flex-row mb-2 gap-2">
              {tags.map((tag) => (
                <li class="flex items-center justify-center">
                  <span
                    class={`flex gap-x-2 rounded-full text-xs ${tag.class} py-1 px-2 `}
                  >
                    <tag.icon class="size-4" />
                    {tag.name}
                  </span>
                </li>
              ))}
            </ul>

            <div class="mt-2 text-gray-700 dark:text-gray-400">
              {description}
            </div>
            <footer class="flex items-end justify-start mt-4 gap-x-4">
              {github && (
                <LinkButton href={github}>
                  <GitHub class="size-6" />
                  {projectsContent.codeLabel}
                </LinkButton>
              )}
              {link && (
                <LinkButton href={link}>
                  <Link class="size-4" />
                  {projectsContent.previewLabel}
                </LinkButton>
              )}
            </footer>
          </div>
        </div>
      </article>
    ))
  }
</div>

---
import { getLangFromUrl } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);

const aboutContent = {
  es: {
    personalImageAlt: "Julio Rodríguez",
    firstParagraph:
      "Me llamo Julio David Rodríguez Ureche. Inicié en la programación a los 18 años mientras cursaba Ingeniería de Sistemas en la Universidad del Magdalena. Actualmente estoy disponible para trabajar.",
    secondParagraph:
      "Algunos de los pasos en mi carrera incluyen trabajar en el proyecto ISODOC, dentro de mi trabajo en Siscómputo LTDA, trabajar como Software Engineer para Cuculi Inc., una startup de EE.UU. y formar parte de grupos de investigación universitarios. Soy una persona autodidacta, apasionada por la tecnología y por construir soluciones útiles y de calidad. Actualmente estoy disponible para trabajar y seguir aprendiendo con nuevos desafíos."
  },
  en: {
    personalImageAlt: "Julio Rodríguez",
    firstParagraph:
      "My name is Julio David Rodríguez Ureche. I started programming at 18 while studying Systems Engineering at Universidad del Magdalena. I am currently available for work.",
    secondParagraph:
      "Some key steps in my career include working on the ISODOC project at Siscómputo LTDA, working as a Software Engineer for Cuculi Inc., a U.S. startup, and participating in university research groups. I am a self-taught person, passionate about technology and building useful, high-quality solutions. I am currently available for work and eager to keep learning through new challenges."
  }
} as const;

const content = aboutContent[lang] ?? aboutContent.es;
---

<article
  class="flex flex-col items-center justify-center gap-8 text-gray-700 dark:text-gray-300 md:flex-row"
>
  <div
    class="[&>p]:mb-4 [&>p>strong]:text-yellow-500 dark:[&>p>strong]:text-yellow-100 [&>p>strong]:font-normal [&>p>strong]:font-mono text-pretty order-2 md:order-1"
  >
    <p>
      {content.firstParagraph}
    </p>

    <p>
      {content.secondParagraph}
    </p>
  </div>

  <img
    width="200"
    height="200"
    src="/profile-image-yellow.webp"
    alt={content.personalImageAlt}
    class="order-1 object-cover w-64 h-full p-1 md:order-2 rotate-3 lg:p-2 lg:w-64 aspect-square rounded-2xl bg-black/20 dark:bg-yellow-500/5 ring-1 ring-black/70 dark:ring-white/20"
    style="object-position: 50% 50%"
  />
</article>


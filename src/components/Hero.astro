---
import Badge from "@/components/Badge.astro";
import LinkedInIcon from "@/components/icons/LinkedIn.astro";
import MailIcon from "@/components/icons/Mail.astro";
import SocialPill from "@/components/SocialPill.astro";
import { getLangFromUrl } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);

const heroContent = {
  es: {
    personalImageAlt: "Julio David Rodríguez Ureche",
    badge: "Disponible para trabajar",
    heading: "Hey, soy Julio Rodríguez",
    introStart: "+1 año de experiencia.",
    introStrong: "Ingeniero de sistemas disponible para trabajar",
    introEnd:
      "actualmente ubicado en Lima, Lima, Perú. Especializado en el desarrollo de aplicaciones únicas.",
    contactCta: "Contáctame"
  },
  en: {
    personalImageAlt: "Julio David Rodríguez Ureche",
    badge: "Available for work",
    heading: "Hey, I'm Julio Rodríguez",
    introStart: "+1 year of experience.",
    introStrong: "Systems engineer available for work",
    introEnd:
      "currently based in Lima, Peru. Specialized in building unique applications.",
    contactCta: "Contact me"
  }
} as const;

const content = heroContent[lang] ?? heroContent.es;
---

<div class="max-w-xl">
  <div class="flex gap-4 mb-4">
    <img
      class="rounded-full shadow-lg size-16 object-cover"
      src="/profile-image-yellow.webp"
      alt={content.personalImageAlt}
    />
    <a
      href="https://www.linkedin.com/in/juliorodriguezureche--/"
      target="_blank"
      rel="noopener"
      class="flex items-center transition md:justify-center md:hover:scale-105"
    >
      <Badge>{content.badge}</Badge>
    </a>
  </div>
  <h1
    class="text-4xl font-bold tracking-tight text-gray-800 sm:text-5xl dark:text-white"
  >
    {content.heading}
  </h1>
  <p
    class="mt-6 text-xl text-gray-800 dark:[&>strong]:text-yellow-200 [&>strong]:text-yellow-500 [&>strong]:font-semibold dark:text-gray-300"
  >
    {content.introStart} <strong>{content.introStrong}</strong>, {content.introEnd}
  </p>
  <nav class="flex flex-wrap gap-4 mt-8">
    <SocialPill href="mailto:jrodriguezdu7@gmail.com">
      <MailIcon class="size-4" />
      {content.contactCta}
    </SocialPill>
    <SocialPill href="https://www.linkedin.com/in/juliorodriguezureche--/">
      <LinkedInIcon class="size-4" />
      LinkedIn
    </SocialPill>
  </nav>
</div>
